{
  "name": "animation-accessibility-tests",
  "version": "1.0.0",
  "description": "Property-based tests for animation accessibility compliance",
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:accessibility": "jest tests/accessibility.test.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "dev": "npx http-server . -p 8000 -c-1 --cors -o /index.html"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "moduleFileExtensions": ["js"],
    "testMatch": ["**/tests/**/*.test.js"]
  }
}